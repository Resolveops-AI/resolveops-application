{
  "title": "QuickHaul Kubernetes Metrics",
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "type": "timeseries",
      "title": "Pod Restarts (Dev/Prod)",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (pod) (kube_pod_container_status_restarts_total{namespace=~\"quickhaul-dev|quickhaul-prod\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU Usage (cores)",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (pod) (node_namespace_pod_container:container_cpu_usage_seconds_total:sum_irate{namespace=~\"quickhaul-dev|quickhaul-prod\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage (bytes)",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"quickhaul-dev|quickhaul-prod\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    }
  ]
}
